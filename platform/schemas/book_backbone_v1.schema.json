{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valley-k-small.dev/schemas/book_backbone_v1.schema.json",
  "title": "Book Backbone V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "chapter_count", "acts", "chapter_spine", "quality_checks"],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "chapter_count": { "type": "integer", "minimum": 1 },
    "acts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["act_id", "title_en", "title_cn", "objective_en", "objective_cn", "chapter_ids"],
        "properties": {
          "act_id": { "type": "string", "minLength": 1 },
          "title_en": { "type": "string", "minLength": 1 },
          "title_cn": { "type": "string", "minLength": 1 },
          "objective_en": { "type": "string", "minLength": 1 },
          "objective_cn": { "type": "string", "minLength": 1 },
          "chapter_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "chapter_spine": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chapter_id",
          "order",
          "title_en",
          "title_cn",
          "core_question_en",
          "core_question_cn",
          "input_dependencies",
          "output_to",
          "key_claim_ids",
          "key_formulae",
          "key_notions",
          "evidence_report_ids",
          "transition_to_next_en",
          "transition_to_next_cn",
          "interactive_count",
          "claim_count",
          "formula_count"
        ],
        "properties": {
          "chapter_id": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 0 },
          "title_en": { "type": "string", "minLength": 1 },
          "title_cn": { "type": "string", "minLength": 1 },
          "core_question_en": { "type": "string", "minLength": 1 },
          "core_question_cn": { "type": "string", "minLength": 1 },
          "input_dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "output_to": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "key_claim_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "key_formulae": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "key_notions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_report_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "transition_to_next_en": { "type": "string", "minLength": 1 },
          "transition_to_next_cn": { "type": "string", "minLength": 1 },
          "interactive_count": { "type": "integer", "minimum": 0 },
          "claim_count": { "type": "integer", "minimum": 0 },
          "formula_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "quality_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "pass", "details"],
        "properties": {
          "check": { "type": "string", "minLength": 1 },
          "pass": { "type": "boolean" },
          "details": {}
        }
      }
    }
  }
}
