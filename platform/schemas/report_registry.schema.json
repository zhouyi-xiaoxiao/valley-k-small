{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report Registry",
  "type": "object",
  "required": ["version", "reports"],
  "properties": {
    "version": {"type": "integer", "const": 3},
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "aliases",
          "path",
          "manuscript_dir",
          "artifact_dir",
          "main_tex",
          "entry_scripts",
          "languages",
          "archive_policy",
          "status"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "aliases": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
          },
          "path": {"type": "string", "pattern": "^research/reports/[a-z0-9_./-]+$"},
          "manuscript_dir": {"type": "string", "const": "manuscript"},
          "artifact_dir": {"type": "string", "const": "artifacts"},
          "main_tex": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[a-zA-Z0-9_.\\-/]+\\.tex$"}
          },
          "entry_scripts": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-zA-Z0-9_.\\-/]+\\.py$"}
          },
          "languages": {
            "type": "array",
            "items": {"type": "string", "enum": ["cn", "en"]},
            "minItems": 1
          },
          "archive_policy": {
            "type": "string",
            "enum": ["latest_only_archive_runs", "keep"]
          },
          "status": {"type": "string", "enum": ["active", "deprecated", "archived"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
