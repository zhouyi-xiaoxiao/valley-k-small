{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valley-k-small.dev/schemas/agent_sync_v1.schema.json",
  "title": "Agent Sync V1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "generated_at", "report_count", "files", "hashes"],
      "properties": {
        "version": { "type": "string", "const": "v1" },
        "generated_at": { "type": "string", "format": "date-time" },
        "report_count": { "type": "integer", "minimum": 0 },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reports_jsonl",
            "events_jsonl",
            "book_manifest",
            "book_chapters_jsonl",
            "claim_graph_jsonl",
            "book_claim_coverage",
            "translation_qc",
            "theory_map",
            "guide_json",
            "report_network",
            "content_map"
          ],
          "properties": {
            "reports_jsonl": { "type": "string", "pattern": "^/data/v1/agent/reports\\.jsonl$" },
            "events_jsonl": { "type": "string", "pattern": "^/data/v1/agent/events\\.jsonl$" },
            "book_manifest": { "type": "string", "pattern": "^/data/v1/agent/book_manifest\\.json$" },
            "book_chapters_jsonl": { "type": "string", "pattern": "^/data/v1/agent/book_chapters\\.jsonl$" },
            "claim_graph_jsonl": { "type": "string", "pattern": "^/data/v1/agent/claim_graph\\.jsonl$" },
            "book_claim_coverage": { "type": "string", "pattern": "^/data/v1/book/book_claim_coverage\\.json$" },
            "translation_qc": { "type": "string", "pattern": "^/data/v1/agent/translation_qc\\.json$" },
            "theory_map": { "type": "string", "pattern": "^/data/v1/theory_map\\.json$" },
            "guide_json": { "type": "string", "pattern": "^/data/v1/agent/guide\\.json$" },
            "report_network": { "type": "string", "pattern": "^/data/v1/report_network\\.json$" },
            "content_map": { "type": "string", "pattern": "^/data/v1/content_map\\.json$" }
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reports_jsonl_sha256",
            "events_jsonl_sha256",
            "book_manifest_sha256",
            "book_chapters_jsonl_sha256",
            "claim_graph_jsonl_sha256",
            "book_claim_coverage_sha256",
            "translation_qc_sha256",
            "report_network_sha256",
            "content_map_sha256"
          ],
          "properties": {
            "reports_jsonl_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "events_jsonl_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "book_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "book_chapters_jsonl_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "claim_graph_jsonl_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "book_claim_coverage_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "translation_qc_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "report_network_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "content_map_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "report_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "group",
        "path",
        "languages",
        "updated_at",
        "title",
        "summary",
        "key_findings",
        "narrative",
        "formula_count",
        "section_count",
        "repro_command_count",
        "dataset_count",
        "asset_count",
        "dataset_series_ids"
      ],
      "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "languages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "updated_at": { "type": "string", "format": "date-time" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "key_findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "narrative": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_overview", "method_overview", "result_overview"],
          "properties": {
            "model_overview": { "type": "string" },
            "method_overview": { "type": "string" },
            "result_overview": { "type": "string" }
          }
        },
        "formula_count": { "type": "integer", "minimum": 0 },
        "section_count": { "type": "integer", "minimum": 0 },
        "repro_command_count": { "type": "integer", "minimum": 0 },
        "dataset_count": { "type": "integer", "minimum": 0 },
        "asset_count": { "type": "integer", "minimum": 0 },
        "dataset_series_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "report_id", "timestamp", "dataset_count", "asset_count", "formula_count"],
      "properties": {
        "event": { "type": "string", "const": "report_synced" },
        "report_id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "dataset_count": { "type": "integer", "minimum": 0 },
        "asset_count": { "type": "integer", "minimum": 0 },
        "formula_count": { "type": "integer", "minimum": 0 }
      }
    },
    "book_chapter_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_id",
        "order",
        "title_en",
        "title_cn",
        "report_ids",
        "interactive_count",
        "claim_count",
        "theory_chain_count",
        "source_paths"
      ],
      "properties": {
        "chapter_id": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 0 },
        "title_en": { "type": "string", "minLength": 1 },
        "title_cn": { "type": "string", "minLength": 1 },
        "report_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "interactive_count": { "type": "integer", "minimum": 1 },
        "claim_count": { "type": "integer", "minimum": 0 },
        "theory_chain_count": { "type": "integer", "minimum": 1 },
        "source_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "claim_graph_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "report_id",
        "stage",
        "linked_claim_ids",
        "linked_report_ids",
        "evidence_paths",
        "evidence_count"
      ],
      "properties": {
        "claim_id": { "type": "string", "minLength": 1 },
        "report_id": { "type": "string", "minLength": 1 },
        "stage": { "type": "string", "enum": ["model", "method", "result", "finding"] },
        "linked_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "linked_report_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
