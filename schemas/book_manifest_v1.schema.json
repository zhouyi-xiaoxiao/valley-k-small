{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valley-k-small.dev/schemas/book_manifest_v1.schema.json",
  "title": "Book Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "chapter_count",
    "chapters",
    "toc",
    "report_chapter_map",
    "quality_checks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "chapter_count": {
      "type": "integer",
      "minimum": 1
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chapter_id",
          "order",
          "slug",
          "title_en",
          "title_cn",
          "summary_en",
          "summary_cn",
          "report_ids",
          "concept_ids",
          "interactive_count",
          "claim_count",
          "estimated_read_minutes",
          "previous_chapter_id",
          "next_chapter_id"
        ],
        "properties": {
          "chapter_id": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "title_en": {
            "type": "string",
            "minLength": 1
          },
          "title_cn": {
            "type": "string",
            "minLength": 1
          },
          "summary_en": {
            "type": "string",
            "minLength": 1
          },
          "summary_cn": {
            "type": "string",
            "minLength": 1
          },
          "report_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "concept_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "interactive_count": {
            "type": "integer",
            "minimum": 1
          },
          "claim_count": {
            "type": "integer",
            "minimum": 0
          },
          "estimated_read_minutes": {
            "type": "integer",
            "minimum": 1
          },
          "previous_chapter_id": {
            "type": ["string", "null"]
          },
          "next_chapter_id": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "toc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "cn"],
      "properties": {
        "en": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chapter_id", "order", "title", "path"],
            "properties": {
              "chapter_id": { "type": "string", "minLength": 1 },
              "order": { "type": "integer", "minimum": 0 },
              "title": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "pattern": "^/book/" }
            }
          }
        },
        "cn": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chapter_id", "order", "title", "path"],
            "properties": {
              "chapter_id": { "type": "string", "minLength": 1 },
              "order": { "type": "integer", "minimum": 0 },
              "title": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "pattern": "^/book/" }
            }
          }
        }
      }
    },
    "report_chapter_map": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["primary_chapter_id", "chapter_ids"],
        "properties": {
          "primary_chapter_id": { "type": "string", "minLength": 1 },
          "chapter_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "quality_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "pass", "details"],
        "properties": {
          "check": { "type": "string", "minLength": 1 },
          "pass": { "type": "boolean" },
          "details": {}
        }
      }
    }
  }
}
